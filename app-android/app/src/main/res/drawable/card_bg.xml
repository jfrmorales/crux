<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo de "tarjeta" para las secciones de la UI. Translúcido gris para que se vea
     bien tanto en tema claro como oscuro, sin depender de un tema Material. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <corners android:radius="16dp" />
    <solid android:color="#14808080" />
    <stroke android:width="1dp" android:color="#33808080" />
</shape>
